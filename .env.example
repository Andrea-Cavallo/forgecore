# ForgeCore local environment
#
# Copy this file to `.env` for Docker Compose:
#   Copy-Item .env.example .env
#
# Compose loads this file automatically. Services also support YAML through
# FORGECORE_CONFIG_FILE, with priority: SDK defaults < YAML < ENV.

# PostgreSQL used by the local stack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=forgecore
POSTGRES_PASSWORD=changeme
POSTGRES_DB=forgecore

# Runtime database URL used by services when they run in Docker Compose
DATABASE_URL=postgres://forgecore:changeme@postgres:5432/forgecore?sslmode=disable

# Migration URLs used by scripts/migrate.sh from the host machine
AUTH_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable
PAYMENT_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable
NOTIFICATION_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable
AUDIT_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable
PERMISSION_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable
CONFIG_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable
WEBHOOK_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable
STORAGE_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable
SUBSCRIPTION_DATABASE_URL=postgres://forgecore:changeme@localhost:5432/forgecore?sslmode=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# NATS
NATS_URL=nats://nats:4222

# JWT
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Encryption / PII
PII_ENCRYPTION_KEY=changeme32byteskeyforAES256here!
PII_PEPPER=changeme32bytespepperforHMAChere!

# Frontend / API Gateway
GATEWAY_PORT=8080
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
AUTH_GRPC_ADDR=forgecore-auth:9091
AUTH_SERVICE_URL=http://forgecore-auth:8081
PAYMENT_SERVICE_URL=http://forgecore-payments:8082
NOTIF_SERVICE_URL=http://forgecore-notifications:8083
ADMIN_SERVICE_URL=http://forgecore-admin:8084
AUDIT_SERVICE_URL=http://forgecore-audit:8085
PERMISSION_SERVICE_URL=http://forgecore-permissions:8087
CONFIG_SERVICE_URL=http://forgecore-config:8088
WEBHOOK_SERVICE_URL=http://forgecore-webhooks:8089
STORAGE_SERVICE_URL=http://forgecore-storage:8090
SUBS_SERVICE_URL=http://forgecore-subscriptions:8091

# Auth Service
AUTH_PORT=8081
AUTH_GRPC_PORT=9091

# Payment Service
PAYMENT_PORT=8082
PAYMENT_GRPC_PORT=9092
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme

# Notification Service
NOTIFICATION_PORT=8083
SENDGRID_API_KEY=SG.changeme
FROM_EMAIL=no-reply@forgecore.local
FROM_NAME=ForgeCore
TWILIO_ACCOUNT_SID=changeme
TWILIO_AUTH_TOKEN=changeme
TWILIO_FROM_NUMBER=+1234567890

# Admin Service
ADMIN_PORT=8084

# Audit Service
AUDIT_PORT=8085
AUDIT_GRPC_PORT=9095

# Job Service
JOB_CONCURRENCY=10

# Permission Service
PERMISSION_PORT=8087
PERMISSION_GRPC_PORT=9097

# Config Service
CONFIG_PORT=8088
CONFIG_GRPC_PORT=9098

# Webhook Service
WEBHOOK_PORT=8089

# Storage Service
STORAGE_PORT=8090
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SSL=false
MINIO_BUCKET=forgecore

# Subscription Service
SUBSCRIPTION_PORT=8091
SUBSCRIPTION_GRPC_PORT=9099

# Observability
OTEL_ENDPOINT=jaeger:4318
OTEL_INSECURE=true

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Local seed
SUPERADMIN_EMAIL=admin@forgecore.local
SUPERADMIN_PASSWORD=ChangeMe123!
