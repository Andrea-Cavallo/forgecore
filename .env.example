# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=superpowers
POSTGRES_PASSWORD=changeme
POSTGRES_DB=superpowers

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# NATS
NATS_URL=nats://nats:4222

# JWT
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Encryption / PII
PII_ENCRYPTION_KEY=changeme32byteskeyforAES256here!
PII_PEPPER=changeme32bytespepperforHMAChere!

# Auth Service
AUTH_PORT=8081
AUTH_GRPC_PORT=9091

# Payment Service
PAYMENT_PORT=8082
PAYMENT_GRPC_PORT=9092
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme

# Notification Service
NOTIFICATION_PORT=8083
SENDGRID_API_KEY=SG.changeme
TWILIO_ACCOUNT_SID=changeme
TWILIO_AUTH_TOKEN=changeme
TWILIO_FROM_NUMBER=+1234567890

# Admin Service
ADMIN_PORT=8084

# Audit Service
AUDIT_PORT=8085
AUDIT_GRPC_PORT=9095

# Job Service
JOB_CONCURRENCY=10

# Permission Service
PERMISSION_PORT=8087
PERMISSION_GRPC_PORT=9097

# Config Service
CONFIG_PORT=8088
CONFIG_GRPC_PORT=9098

# Webhook Service
WEBHOOK_PORT=8089

# Storage Service
STORAGE_PORT=8090
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=superpowers

# Subscription Service
SUBSCRIPTION_PORT=8091
SUBSCRIPTION_GRPC_PORT=9099

# Observability
OTEL_ENDPOINT=jaeger:4318
OTEL_INSECURE=true

# API Gateway
GATEWAY_PORT=8080

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
