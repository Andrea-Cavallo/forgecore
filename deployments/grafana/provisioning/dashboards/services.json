{
  "title": "Superpowers — Services Overview",
  "uid": "superpowers-services",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (job)",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (%)",
      "id": 2,
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) by (job) / sum(rate(http_requests_total[1m])) by (job) * 100",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latenza p99 (ms)",
      "id": 3,
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (job, le)) * 1000",
          "legendFormat": "{{ job }} p99"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Servizi attivi",
      "id": 4,
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Up"
        }
      ]
    }
  ]
}
